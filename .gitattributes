# Normalize all text files
* text=auto

# Python project files use LF
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
*.zip -text
*.exe -text
